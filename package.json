{
  "name": "tmp-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:components": "vitest run tests/components",
    "test:accessibility": "vitest run tests/accessibility",
    "test:spa": "node scripts/test-spa-fallback.mjs",
    "test:e2e": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-e2e.ps1 -Project chromium-desktop-dark",
    "test:e2e:cross-browser": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-e2e.ps1",
    "test:import": "node scripts/import-dry-run.mjs",
    "test:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-backup-restore.ps1",
    "test:qa": "npm run test:unit && npm run test:components && npm run test:accessibility && npm run test:import && npm run typecheck && npm run build && npm run lint",
    "test:phase3": "npm run test:qa",
    "preview": "vite preview",
    "db:start": "supabase start",
    "db:reset": "supabase db reset --local",
    "db:test": "supabase test db",
    "db:test:concurrency": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-concurrency.ps1",
    "db:lint": "supabase db lint --local --level warning",
    "db:types": "node scripts/generate-database-types.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.108.2",
    "jsbarcode": "3.12.3",
    "lucide-react": "1.18.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.17.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/vite": "4.3.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jsbarcode": "3.11.4",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "axe-core": "4.12.1",
    "csv-parse": "7.0.1",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.6.0",
    "jsdom": "29.1.1",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.1",
    "vite": "8.0.16",
    "vitest": "4.1.10"
  }
}
